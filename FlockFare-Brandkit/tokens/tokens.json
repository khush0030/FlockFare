{
  "$brand": "FlockFare",
  "$version": "1.0.0",
  "$style": "Neo-Brutalist",
  "color": {
    "core": {
      "ink":        { "value": "#0B0B0F" },
      "ink-soft":   { "value": "#1A1A22" },
      "cream":      { "value": "#F6F3EC" },
      "paper":      { "value": "#FFFFFF" },
      "violet":     { "value": "#6D28FF" },
      "violet-deep":{ "value": "#2A1470" },
      "violet-tint":{ "value": "#EFE6FF" },
      "lime":       { "value": "#D8FF3C" },
      "lime-tint":  { "value": "#F3FFC7" },
      "coral":      { "value": "#FF4E64" },
      "coral-tint": { "value": "#FFE5ED" },
      "sun":        { "value": "#FFD166" }
    },
    "gray": {
      "50":  "#FAFAF6",
      "100": "#F1F1EC",
      "200": "#E2E2DD",
      "300": "#C9C9C4",
      "400": "#9C9C98",
      "500": "#6A6A67",
      "600": "#4A4A48",
      "700": "#2F2F2D"
    },
    "semantic": {
      "background":    "cream",
      "foreground":    "ink",
      "surface":       "paper",
      "border":        "ink",
      "link":          "violet",
      "success":       "#00B775",
      "warning":       "sun",
      "danger":        "coral",
      "focus-ring":    "violet"
    }
  },
  "font": {
    "display": "Bricolage Grotesque, Archivo Black, system-ui, sans-serif",
    "body":    "DM Sans, Inter, system-ui, sans-serif",
    "mono":    "JetBrains Mono, IBM Plex Mono, ui-monospace, monospace"
  },
  "fontSize": {
    "12": "0.75rem", "14": "0.875rem", "16": "1rem",
    "18": "1.125rem", "24": "1.5rem", "32": "2rem",
    "44": "2.75rem", "60": "3.75rem", "80": "5rem"
  },
  "fontWeight": { "regular": 400, "medium": 500, "bold": 700, "black": 900 },
  "lineHeight": { "tight": 1.02, "snug": 1.14, "base": 1.5, "loose": 1.7 },
  "letterSpacing": { "display": "-0.03em", "head": "-0.02em", "body": "-0.005em", "mono": "0.18em" },
  "space": {
    "1": 4, "2": 8, "3": 12, "4": 16, "5": 20, "6": 24, "8": 32, "10": 40, "12": 48, "16": 64, "20": 80, "24": 96
  },
  "radius": {
    "sm":   "6px",
    "base": "12px",
    "lg":   "20px",
    "xl":   "28px",
    "pill": "999px"
  },
  "borderWidth": { "hair": "1px", "base": "2px", "bold": "4px" },
  "shadow": {
    "brut-sm":      "3px 3px 0 #0B0B0F",
    "brut":         "6px 6px 0 #0B0B0F",
    "brut-lg":      "10px 10px 0 #0B0B0F",
    "brut-violet":  "6px 6px 0 #6D28FF",
    "brut-coral":   "6px 6px 0 #FF4E64",
    "soft":         "0 1px 2px rgba(11,11,15,0.06), 0 4px 12px rgba(11,11,15,0.06)"
  },
  "motion": {
    "duration": { "1": "120ms", "2": "220ms", "3": "360ms", "4": "520ms" },
    "easing": {
      "out": "cubic-bezier(0.2, 0.8, 0.2, 1)",
      "in":  "cubic-bezier(0.4, 0, 1, 1)",
      "ioq": "cubic-bezier(0.83, 0, 0.17, 1)"
    }
  },
  "layout": {
    "container":    "1200px",
    "container-md": "896px",
    "container-sm": "680px"
  }
}
